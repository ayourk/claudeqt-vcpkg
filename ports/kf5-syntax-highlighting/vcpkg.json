{
  "name": "kf5-syntax-highlighting",
  "version": "5.115.0",
  "port-version": 1,
  "description": "KDE Frameworks syntax highlighting engine (Qt6 backport mode)",
  "homepage": "https://api.kde.org/frameworks/syntax-highlighting/",
  "license": null,
  "dependencies": [
    { "name": "vcpkg-cmake", "host": true },
    { "name": "vcpkg-cmake-config", "host": true },
    "extra-cmake-modules",
    {
      "name": "freetype",
      "default-features": false,
      "features": ["bzip2", "zlib"]
    },
    {
      "name": "qtbase",
      "default-features": false,
      "features": ["gui", "network", "widgets"]
    }
  ]
}
